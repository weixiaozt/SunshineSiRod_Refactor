</oc>
</interface>
<body>
<c></c>
<l>select_shape_xld (SelectedXLDT, SelectedXLDt1, ['rect2_phi','contlength'], 'and', [-0.2,50], [0.2,10000])</l>
<l>union_collinear_contours_xld (SelectedXLDt1, SelectedXLDt1, 200, 200, 2, 0.5, 'attr_keep')</l>
<c></c>
<l>fit_line_contour_xld (SelectedXLDt1, 'tukey', -1, 0, 5, 2, RowBegin, ColBegin, RowEnd, ColEnd, Nr, Nc, Dist)</l>
<c></c>
<l>tuple_abs (Nc, Abs1)</l>
<l>tuple_asin (Abs1, ASin1)</l>
<l>try</l>
<l>    tuple_length (Abs1, Length)</l>
<c></c>
<l>    if (Length&gt;1)</l>
<l>        select_obj (SelectedXLDt1, SelectedXLDt1, 1)</l>
<l>    endif</l>
<l>catch (Exception)</l>
<l>endtry</l>
<c></c>
<l>* rota_xld (SelectedXLDt1, SelectedXLDt1, -VALUE)</l>
<c></c>
