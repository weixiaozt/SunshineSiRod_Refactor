<procedure name="XLD_Edge">
<interface>
<io>
<par name="ImageTopPart" base_type="iconic" dimension="0"/>
</io>
<oo>
<par name="SelectedXLDT" base_type="iconic" dimension="0"/>
</oo>
<ic>
<par name="Index" base_type="ctrl" dimension="0"/>
</ic>
</interface>
<body>
<l>gen_rectangle1 (Rectangle5, Index, 500, Index, 3199)</l>
<l>* threshold (ImageTopPart, Region1, -15, 15)</l>
<l>* intersection (Rectangle5, Region1, RegionIntersection)</l>
<l>* reduce_domain (ImageTopPart, RegionIntersection, ImageReduced)</l>
<l>* crop_domain (ImageReduced, ImagePart)</l>
<l>get_region_points (Rectangle5, Rows5, Columns5)</l>
<l>get_grayval (ImageTopPart, Rows5, Columns5, grayvalues5)</l>
<c></c>
<l>tuple_find (grayvalues5, -10000, Indices)</l>
<l>grayvalues5[Indices] := 100000</l>
<l>tuple_gen_sequence (0, (|grayvalues5|-1), 1, Sequence1)</l>
<l>gen_contour_polygon_xld (Contour1, grayvalues5/0.015, Sequence1)</l>
<c></c>
<c></c>
<l>segment_contours_xld (Contour1, ContoursSplit, 'lines_circles', 40, 1, 1)</l>
<l>select_shape_xld (ContoursSplit, SelectedXLD, 'phi', 'and', -3.14, 3.14)</l>
<l>select_shape_xld (SelectedXLD, SelectedXLD, 'contlength', 'and', 0, 10000)</l>
<l>select_shape_xld (SelectedXLD, SelectedXLDT, 'row1', 'and', -3000, 3000)</l>
<c></c>
<l>return ()</l>
</body>
