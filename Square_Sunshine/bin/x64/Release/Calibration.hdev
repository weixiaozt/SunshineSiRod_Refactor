<l>    get_contour_xld (SelectedXLDt1, Row, Col)</l>
<l>    tuple_mean (Row, Mean1)</l>
<c></c>
<l>catch (Exception)</l>
<l>    Mean1 := 0</l>
<l>endtry</l>
<c></c>
<c></c>
<l>Mean1 := Mean1*0.015</l>
<c></c>
<l>return ()</l>
</body>
