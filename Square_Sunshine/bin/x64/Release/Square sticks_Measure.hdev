<procedure name="DJ_JUGE">
<interface>
<io>
<par name="SelectedXLDT" base_type="iconic" dimension="0"/>
</io>
<ic>
<par name="VALUE" base_type="ctrl" dimension="0"/>
</ic>
<oc>
<par name="Mean1" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<c></c>
<l>select_shape_xld (SelectedXLDT, SelectedXLDt1, ['rect2_phi','contlength'], 'and', [-0.2,50], [0.2,10000])</l>
<l>union_collinear_contours_xld (SelectedXLDt1, SelectedXLDt1, 200, 200, 2, 0.5, 'attr_keep')</l>
<c></c>
<l>fit_line_contour_xld (SelectedXLDt1, 'tukey', -1, 0, 5, 2, RowBegin, ColBegin, RowEnd, ColEnd, Nr, Nc, Dist)</l>
<c></c>
<l>tuple_abs (Nc, Abs1)</l>
<l>tuple_asin (Abs1, ASin1)</l>
<l>try</l>
<l>   tuple_length (Abs1, Length)</l>
<c></c>
<l>if (Length&gt;1)</l>
<l>    select_obj (SelectedXLDt1, SelectedXLDt1, 1)</l>
<l>endif </l>
<l>catch (Exception)</l>
<l>endtry</l>
<c></c>
<l>*rota_xld (SelectedXLDt1, SelectedXLDt1, -VALUE)</l>
<c></c>
<l>try</l>
<l>    get_contour_xld (SelectedXLDt1, Row, Col)</l>
<l>    tuple_mean (Row, Mean1)</l>
<c></c>
<l>catch (Exception)</l>
<l>    Mean1 := 0</l>
<l>endtry</l>
<c></c>
<c></c>
<l>Mean1 := Mean1*0.015</l>
<c></c>
<l>return ()</l>
</body>
<docu id="DJ_JUGE">
<parameters>
<parameter id="Mean1"/>
<parameter id="SelectedXLDT"/>
<parameter id="VALUE"/>
</parameters>
</docu>
</procedure>
