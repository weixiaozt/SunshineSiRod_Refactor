<procedure name="Point_COPY_3">
<interface>
<io>
<par name="ContoursSplitT" base_type="iconic" dimension="0"/>
</io>
<oc>
<par name="Row" base_type="ctrl" dimension="0"/>
<par name="Column" base_type="ctrl" dimension="0"/>
<par name="ARCL" base_type="ctrl" dimension="0"/>
<par name="angle" base_type="ctrl" dimension="0"/>
</oc>
</interface>
<body>
<l>try</l>
<c></c>
<c></c>
<l>    select_shape_xld (ContoursSplitT, SelectedXLT1, ['rect2_phi','contlength'], 'and', [-0.9,400], [-0.6,9000000])</l>
<l>    union_collinear_contours_xld (SelectedXLT1, SelectedXLT1, 1000, 1000, 2, 0.5, 'attr_keep')</l>
<l>    fit_line_contour_xld (SelectedXLT1, 'tukey', -1, 0, 5, 2, Line1Row1, Line1Column1, Line1Row2, Line1Column2, Nr, Nc, Dist)</l>
<c>  </c>
<c>    </c>
<l>    select_shape_xld (ContoursSplitT, SelectedXLT2, ['rect2_phi','contlength'], 'and', [0.6,300], [0.9,9000000])</l>
<c></c>
<l>    union_collinear_contours_xld (SelectedXLT2, SelectedXLT2, 500, 500, 2, 0.5, 'attr_keep')</l>
<l>    fit_line_contour_xld (SelectedXLT2, 'tukey', -1, 0, 5, 2, Line2Row1, Line2Column1, Line2Row2, Line2Column2, Nr, Nc, Dist)</l>
<c></c>
<l>    try</l>
<c> </c>
<l>    angle_lx (Line1Row1, Line1Column1, Line1Row2, Line1Column2, Angle1)</l>
<l>    angle_lx (Line2Row1, Line2Column1, Line2Row2, Line2Column2, Angle2)</l>
<l>    tuple_deg (Angle1, Angle1)</l>
<l>    tuple_deg (Angle2, Angle2)</l>
<l>    tuple_abs (Angle1, Angle1)</l>
<l>    tuple_abs (Angle2, Angle2)</l>
<l>      angle:=180-Angle1-Angle2</l>
<c>         </c>
<l>    catch (Exception)</l>
<l>    endtry</l>
<c>    </c>
<c>    </c>
<c></c>
<l>    select_shape_xld (ContoursSplitT, SelectedXLT3, ['rect2_phi','contlength'], 'and', [-0.2,40], [0.2,9000000])</l>
<l>    select_shape_xld (SelectedXLT3, SelectedXLT3, 'column1', 'and', 500, 2500)</l>
<l>    union_collinear_contours_xld (SelectedXLT3, SelectedXLT3, 500, 500, 2, 0.5, 'attr_keep')</l>
<l>    fit_line_contour_xld (SelectedXLT3, 'tukey', -1, 0, 5, 2, Line3Row1, Line3Column1, Line3Row2, Line3Column2, Nr, Nc, Dist)</l>
<c></c>
<c></c>
<c></c>
<c></c>
<c></c>
<l>    intersection_lines (Line1Row1, Line1Column1, Line1Row2, Line1Column2, Line3Row1, Line3Column1, Line3Row2, Line3Column2, Row1, Column1, IsOverlapping)</l>
<c></c>
<l>    intersection_lines (Line3Row1, Line3Column1, Line3Row2, Line3Column2, Line2Row1, Line2Column1, Line2Row2, Line2Column2, Row2, Column2, IsOverlapping)</l>
<c></c>
<l>    intersection_lines (Line1Row1, Line1Column1, Line1Row2, Line1Column2, Line2Row1, Line2Column1, Line2Row2, Line2Column2, Row, Column, IsOverlapping)</l>
<c></c>
<c></c>
<l>    distance_pp (Row1, Column1, Row2, Column2, Distance)</l>
<l>    ARCL := Distance*0.015</l>
<l>catch (Exception)</l>
<l>endtry</l>
<l>return ()</l>
</body>
<docu id="Point_COPY_3">
<parameters>
<parameter id="ARCL"/>
<parameter id="Column"/>
<parameter id="ContoursSplitT"/>
<parameter id="Row"/>
<parameter id="angle"/>
</parameters>
</docu>
</procedure>
</hdevelop>
